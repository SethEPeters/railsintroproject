<div class="container text-center">
  <div class="row bg-primary">
    <div class="col">
      <h1>Doggy Homepage</h1>
    </div>
  </div>
  <div class="row bg-info">
    <div class="col">
      <a href="http://localhost:3000/dog_infos">Index</a>
    </div>
    <div class="col">
      <a href="http://localhost:3000/dog_infos/about">About</a>
    </div>
  </div>
  <div class="row">
    <div class="col">
      <%= form_tag dog_infos_path, :method => 'get' do %>
        <p>
          <%= text_field_tag :search, params[:search] %>
          <%= submit_tag "Search", :name => nil %>
        </p>
      <% end %>
    </div>
  </div>
  <% @doginfos.each do |doginfo| %>
    <div class="row">
      <div class="col">
        <a href="http://localhost:3000/dog_infos/<%= doginfo.id %>" ><%= doginfo.name %></a>
      </div>
    </div>
  <% end %>
  <div class="row">
      <div class="col">
        <%= paginate @doginfos%>
      </div>
    </div>
</div>