<h1>Doginfos#index</h1>
<p> Find me in app/views/dog_infos/index.html.erb</p>

<form action="http://localhost:3000/dog_infos" method="post">
  <label for="search">Search</label>
  <input type="search" id="search" />

  <input type="submit" />
</form>

<ol>
  <% @doginfos.each do |doginfo| %>
    <li><a href="http://localhost:3000/dog_infos/<%= doginfo.id %>" ><%= doginfo.name %></a></li>
  <% end %>
</ol>