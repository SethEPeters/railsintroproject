<div class="container text-center">
  <div class="row bg-primary">
    <div class="col">
      <h1>Welcome to <%= @doginfo.name %>'s Profile</h1>
    </div>
  </div>
  <div class="row bg-info">
    <div class="col">
      <a href="http://localhost:3000/dog_infos">Index</a>
    </div>
    <div class="col">
      <a href="http://localhost:3000/dog_infos/about">About</a>
    </div>
  </div>
  <div class="row">
    <% if @doginfo.id%5==0 %>
      <div class="col">
        <img src="<%= @doginfo.dog_image.dog_image %>" alt="dog profile picture">
      </div>
      <div class="col">
        <img src="<%= @doginfo.dog_image.dog_image %>" alt="dog profile picture">
      </div>
    <% else %>
      <div class="col">
        <img src="<%= @doginfo.dog_image.dog_image %>" alt="dog profile picture">
      </div>
    <% end %>
  </div>
  <div class="row">
    <div class="col">
      <p>Name: <%= @doginfo.name %></p>
    </div>
    <div class="col">
      <p>Age: <%= @doginfo.dog_age %></p>
    </div>
    <div class="col">
      <p>Sound: <%= @doginfo.dog_sound %></p>
    </div>
    <div class="col">
      <p>Breed: <%= @doginfo.dog_breed %></p>
    </div>
  </div>
</div>